{
    "comment": "Optimierte Konfiguration für große DJ-Bibliotheken (300.000+ Dateien)",
    
    "protected_folders": [
        "D:\\Core-Library",
        "D:\\Master-Collection", 
        "D:\\DJ-Sets\\Live-Recordings",
        "D:\\Backup\\Master"
    ],
    
    "source_folders": [
        "D:\\Music\\Unsorted",
        "D:\\Downloads\\Music",
        "E:\\Backup\\Music",
        "F:\\Various\\Audio",
        "G:\\External\\Music"
    ],
    
    "target_folder": "D:\\Bereinigt",
    
    "quality_priority": [
        "flac", 
        "wav", 
        "mp3_320", 
        "mp3_256", 
        "mp3_192", 
        "mp3_128",
        "mp3_vbr",
        "m4a",
        "aac",
        "ogg"
    ],
    
    "performance_settings": {
        "batch_size": 3000,
        "multiprocessing_workers": 12,
        "fingerprint_cache_db": "production_fingerprints.db",
        "resume_enabled": true
    },
    
    "metadata_enrichment": {
        "enable_musicbrainz": true,
        "musicbrainz_contact": "ihre-email@example.com",
        "acoustid_api_key": null
    },
    
    "file_filtering": {
        "min_file_size_mb": 0.5,
        "max_file_size_mb": 100,
        "supported_formats": [".mp3", ".flac", ".wav", ".m4a", ".ogg", ".wma", ".aac"]
    },
    
    "organization": {
        "genre_mapping": "auto",
        "decade_fallback": "2020s",
        "create_backup_list": true
    },
    
    "logging": {
        "log_level": "INFO",
        "dry_run": false
    },
    
